#!/usr/bin/env bash
# Send a message to a Telegram chat via the Bot API.
# Usage: tg-send [--slot KEY] [--html] [--topic ID] "Your message here"
#        echo "message" | tg-send [--slot KEY] [--html] [--topic ID]
#
# --slot KEY  Edit the previous message sent under this slot name instead of
#             creating a new one. Use any string as KEY — it identifies which
#             message to update (e.g. "build-status", "deploy-prod").
#             Falls back to a new message if the previous one was deleted or
#             is too old to edit (Telegram limit: 48 hours).
#             Appends "Last updated H:MM AM/PM" when editing.
#
# --html      Render the message as HTML. Supports <b>, <i>, <code>, <pre>,
#             and other tags supported by Telegram's HTML parse mode.
#             Without this flag, messages are sent as plain text and angle
#             brackets are safe to use literally.
#             With this flag, literal < and > must be escaped as &lt; and &gt;.
#
# --topic ID  Send to a specific topic (thread) in a forum-style supergroup.
#             ID is the message_thread_id of the topic — run get-chat-id.sh
#             and send a message in the topic to find it.
#             When combined with --slot, the slot is scoped to the topic.
#
# Reads credentials from a .env file in the same directory as this script.
# Override the .env location by setting TG_SEND_ENV=/path/to/.env

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="${TG_SEND_ENV:-$SCRIPT_DIR/.env}"

if [[ ! -f "$ENV_FILE" ]]; then
  echo "Error: $ENV_FILE not found." >&2
  echo "Copy .env.example to .env and fill in TELEGRAM_BOT_TOKEN and CHAT_ID." >&2
  exit 1
fi

# python3 stdlib parser — safe for .env files that contain values with spaces.
# bash `source` would break on lines like: WP_APP_PASSWORD=my password with spaces
eval "$(python3 - "$ENV_FILE" <<'PYEOF'
import sys, shlex
wanted = {'TELEGRAM_BOT_TOKEN', 'CHAT_ID'}
with open(sys.argv[1]) as f:
    for line in f:
        line = line.strip()
        if not line or line.startswith('#'):
            continue
        if line.startswith('export '):
            line = line[7:]
        if '=' not in line:
            continue
        key, _, val = line.partition('=')
        key = key.strip()
        if key not in wanted:
            continue
        val = val.strip()
        if val and val[0] in ('"', "'"):
            try:
                val = shlex.split(val)[0]
            except ValueError:
                val = val.strip(val[0])
        else:
            val = val.split('#')[0].rstrip()
        print(f"{key}={shlex.quote(val)}")
PYEOF
)"

if [[ -z "${TELEGRAM_BOT_TOKEN:-}" ]]; then
  echo "Error: TELEGRAM_BOT_TOKEN not set in $ENV_FILE" >&2
  exit 1
fi

if [[ -z "${CHAT_ID:-}" ]]; then
  echo "Error: CHAT_ID not set in $ENV_FILE" >&2
  exit 1
fi

# Parse flags
SLOT=""
HTML_MODE=""
TOPIC_ID=""
ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --slot)
      if [[ $# -lt 2 || -z "${2:-}" ]]; then
        echo "Error: --slot requires a non-empty KEY argument" >&2
        exit 1
      fi
      SLOT="$2"
      shift 2
      ;;
    --html)
      HTML_MODE=1
      shift
      ;;
    --topic)
      if [[ $# -lt 2 || -z "${2:-}" ]]; then
        echo "Error: --topic requires a numeric ID argument" >&2
        exit 1
      fi
      TOPIC_ID="$2"
      shift 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ ${#ARGS[@]} -ge 1 ]]; then
  MESSAGE="${ARGS[*]}"
else
  MESSAGE="$(cat)"
fi

if [[ -z "$MESSAGE" ]]; then
  echo "Error: no message provided" >&2
  exit 1
fi

# The bot token is in API_BASE, a shell variable — not in any command's argv.
# tg_curl feeds the URL to curl via stdin (-K -) so the token never appears
# in the process list (ps aux shows argv, not stdin).
API_BASE="https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}"

tg_curl() {
  local endpoint="$1"
  shift
  curl -s -K - "$@" <<EOF
url = "${API_BASE}/${endpoint}"
EOF
}

api_ok() {
  python3 -c "import json,sys; print(json.load(sys.stdin).get('ok','false'))" 2>/dev/null || echo "false"
}

if [[ -n "$SLOT" ]]; then
  SLOT_KEY="${CHAT_ID}${TOPIC_ID:+:$TOPIC_ID}:${SLOT}"
  IDS_FILE="$(dirname "$ENV_FILE")/.message_ids.json"

  stored_id() {
    [[ ! -f "$IDS_FILE" ]] && echo "" && return
    TG_IDS_FILE="$IDS_FILE" TG_SLOT_KEY="$SLOT_KEY" python3 -c "
import json, os
data = json.load(open(os.environ['TG_IDS_FILE']))
print(data.get(os.environ['TG_SLOT_KEY'], ''))
" 2>/dev/null || echo ""
  }

  save_id() {
    local msg_id="$1"
    TG_IDS_FILE="$IDS_FILE" TG_SLOT_KEY="$SLOT_KEY" TG_MSG_ID="$msg_id" python3 -c "
import json, os, stat
path = os.environ['TG_IDS_FILE']
data = json.load(open(path)) if os.path.exists(path) else {}
data[os.environ['TG_SLOT_KEY']] = os.environ['TG_MSG_ID']
is_new = not os.path.exists(path)
with open(path, 'w') as f:
    json.dump(data, f, indent=2)
if is_new:
    os.chmod(path, stat.S_IRUSR | stat.S_IWUSR)
"
  }

  MSG_ID="$(stored_id)"

  if [[ -n "$MSG_ID" ]]; then
    TIMESTAMP="$(date +'%-I:%M %p')"
    if [[ -n "$HTML_MODE" ]]; then
      EDITED_MESSAGE="${MESSAGE}
<i>Last updated ${TIMESTAMP}</i>"
    else
      EDITED_MESSAGE="${MESSAGE}
Last updated ${TIMESTAMP}"
    fi

    PARSE_MODE_ARG=()
    [[ -n "$HTML_MODE" ]] && PARSE_MODE_ARG=(-d parse_mode="HTML")

    RESPONSE="$(tg_curl "editMessageText" \
      -d chat_id="${CHAT_ID}" \
      -d message_id="${MSG_ID}" \
      "${PARSE_MODE_ARG[@]}" \
      --data-urlencode text="${EDITED_MESSAGE}")"

    if [[ "$(echo "$RESPONSE" | api_ok)" == "True" ]]; then
      echo "Edited message ${MSG_ID}"
      exit 0
    fi
    # Edit failed (message deleted, too old, etc.) — fall through to send new
  fi

  PARSE_MODE_ARG=()
  [[ -n "$HTML_MODE" ]] && PARSE_MODE_ARG=(-d parse_mode="HTML")
  TOPIC_ARG=()
  [[ -n "$TOPIC_ID" ]] && TOPIC_ARG=(-d message_thread_id="${TOPIC_ID}")

  RESPONSE="$(tg_curl "sendMessage" \
    -d chat_id="${CHAT_ID}" \
    "${TOPIC_ARG[@]}" \
    "${PARSE_MODE_ARG[@]}" \
    --data-urlencode text="${MESSAGE}")"

  NEW_ID="$(echo "$RESPONSE" | python3 -c "
import json, sys
d = json.load(sys.stdin)
print(d['result']['message_id'] if d.get('ok') else '')
" 2>/dev/null || echo "")"

  if [[ -z "$NEW_ID" ]]; then
    echo "Error: sendMessage failed: $RESPONSE" >&2
    exit 1
  fi

  save_id "$NEW_ID"
  echo "Sent new message ${NEW_ID}"

else
  PARSE_MODE_ARG=()
  [[ -n "$HTML_MODE" ]] && PARSE_MODE_ARG=(-d parse_mode="HTML")
  TOPIC_ARG=()
  [[ -n "$TOPIC_ID" ]] && TOPIC_ARG=(-d message_thread_id="${TOPIC_ID}")

  RESPONSE="$(tg_curl "sendMessage" \
    -d chat_id="${CHAT_ID}" \
    "${TOPIC_ARG[@]}" \
    "${PARSE_MODE_ARG[@]}" \
    --data-urlencode text="${MESSAGE}")"

  if [[ "$(echo "$RESPONSE" | api_ok)" != "True" ]]; then
    echo "Error: sendMessage failed: $RESPONSE" >&2
    exit 1
  fi

  echo "Sent."
fi
